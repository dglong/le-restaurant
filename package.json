{
  "name": "@long.dg/le-restaurant",
  "version": "0.1.0",
  "description": "Install the brigade of agent skills into your project, translated for your coding agent.",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "le-restaurant": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:sync": "vitest run test/check-skills-sync.test.ts"
  },
  "keywords": [
    "claude",
    "codex",
    "gemini",
    "skills",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^14.0.1",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
